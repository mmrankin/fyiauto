# ---- Upstream inventory warehouse (read-only sync source) ----
INV_DB_SERVER=10.1.2.17
INV_DB_USER=sa
INV_DB_PASSWORD=
INV_DB_DATABASE=inventory

# ---- VIN decode database (squish-VIN -> year/make/model/trim) ----
DECODE_DB_SERVER=10.1.1.10
DECODE_DB_USER=sa
DECODE_DB_PASSWORD=
DECODE_DB_DATABASE=vin_decode

# ---- ip2Location DB (ZIP -> lat/long, for dealer distance search) ----
IP2_DB_SERVER=10.1.1.10
IP2_DB_USER=sa
IP2_DB_PASSWORD=
IP2_DB_DATABASE=ip2Location

# ---- Local serving database ----
# LOCAL_DB_PATH=./fyiauto.db

# ---- AI search (optional; site still works on dropdowns + keyword without it) ----
# Natural-language search + semantic reranking via Claude.
ANTHROPIC_API_KEY=
# Model used to translate a natural-language query into structured filters.
AI_SEARCH_MODEL=claude-haiku-4-5-20251001
# Optional: Voyage embeddings for true vector semantic search. Without this,
# semantic ranking falls back to SQLite FTS5 + Claude reranking.
VOYAGE_API_KEY=

FLASK_SECRET_KEY=dev-change-me

# ---- "Check Availability" button (VDP) ----
# Enrollment is read from the shared platform DB: a dealer with an active
# LEAD_FORM grant links to their lead form; everyone else uses the trade-in
# fallback. Platform dealer_id must equal the fyiAuto tbl_dealer.id.
PLATFORM_DB_PATH=/Users/markrankin/claude/platform/platform.db
LEAD_FORM_BASE_URL=https://lead.dlrpro.com
TRADE_IN_BASE_URL=https://trade.dlrpro.com
CREDIT_EST_BASE_URL=https://credit.dlrpro.com

# "Sell My Car" link in the header (trade-in widget entry).
SELL_MY_CAR_URL=http://localhost:5001/t/DEMO

# Dev sync cap: limit number of vehicles pulled (blank = all active inventory).
SYNC_LIMIT=2000

# Photo source: "field" (default, safe) or "parsedimage". tbl_parsedImage has
# 2.5B rows with disabled indexes today, so "parsedimage" times out until
# indexVIN is rebuilt upstream. See sync.py header.
# SYNC_PHOTOS=field
